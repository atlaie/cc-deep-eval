# Dockerfile.pysyft-spike — Step 2 of the §3.2 feasibility spike.
#
# Bare PySyft Datasite, no vLLM, no encoder. The spike answers exactly one
# question: does PySyft 0.9.5's orchestra Datasite deploy inside a Tinfoil
# container and serve traffic through the shim?
#
# Base note: `python:3.12-bookworm` (not -slim). The slim variant ships
# without libxml2, libxslt, libjpeg, libpng, libfreetype, etc. PySyft's
# transitive deps (lxml, pillow, matplotlib, syftbox->...) link against
# those at runtime, so the slim container crashes on `import syft` even
# though pip install succeeds. We hit this on the first deploy attempt
# (CPU all-zero in metrics, TLS unreachable). Full image trades ~800 MB for
# eliminating the entire "missing native lib" failure class.

FROM python:3.12-bookworm

# Full Debian bookworm has libxml2/libxslt/libjpeg/libpng/etc pre-installed.
# Curl is the only thing we add - needed by the Tinfoil healthcheck command.
RUN apt-get update && apt-get install -y --no-install-recommends \
        curl \
    && rm -rf /var/lib/apt/lists/*

# Pin syft to upstream's currently-stable band. httpx comes in transitively
# via syftbox (which pins httpx==0.28.1); don't install or pin it ourselves
# or the resolver fails.
RUN pip install --no-cache-dir \
        'syft>=0.9.5,<0.9.6'

WORKDIR /workspace
COPY pysyft_datasite_spike_server.py /workspace/pysyft_datasite_spike_server.py

ENV SYFT_PORT=8000 \
    SYFT_DATASITE_NAME=prepilot-spike \
    SYFT_HOME=/workspace/.syft

EXPOSE 8000

ENTRYPOINT ["python", "-u", "/workspace/pysyft_datasite_spike_server.py"]
